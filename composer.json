{
  "name": "stellarsecurity/notification-laravel",
  "description": "Laravel client for Stellar Notification API",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Stellar Security",
      "email": "hello@stellarsecurity.com"
    }
  ],
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "StellarSecurity\\Notifications\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "StellarSecurity\\Notifications\\Providers\\StellarNotificationServiceProvider"
      ],
      "aliases": {
        "Notification": "StellarSecurity\\Notifications\\Facades\\Notification"
      }
    }
  },
  "minimum-stability": "stable"
}
